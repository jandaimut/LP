<script>
document.addEventListener("DOMContentLoaded", function () {
    const track = document.getElementById("jandagacorReviewTrack");
    const cards = Array.from(track.children);
    
    // Menggandakan susunan item ulasan asli di dalam track untuk mendapatkan efek perputaran kontinu tanpa sela
    cards.forEach(card => {
        const clone = card.cloneNode(true);
        track.appendChild(clone);
    });

    let currentSpeed = 0.8; // Kecepatan linear translasi (bisa disesuaikan, 0.8 diatur agar nyaman dibaca)
    let activeSpeed = 0.8;
    let currentX = 0;

    function autoStepReviewSlider() {
        currentX -= activeSpeed;
        
        // Reset koordinat jalur pergeseran tepat setelah setengah total lebar track terlewati keluar layar
        if (Math.abs(currentX) >= (track.scrollWidth / 2)) {
            currentX = 0;
        }
        
        track.style.transform = `translate3d(${currentX}px, 0, 0)`;
        requestAnimationFrame(autoStepReviewSlider);
    }

    // Eksekusi putaran pergerakan track pertama kali
    requestAnimationFrame(autoStepReviewSlider);

    // Fitur Kontrol: Menghentikan pergeseran jika kursor disentuhkan agar pengunjung fokus membaca ulasan tertentu
    track.addEventListener("mouseenter", () => { activeSpeed = 0; });
    track.addEventListener("mouseleave", () => { activeSpeed = currentSpeed; });
    
    // Dukungan Interaktivitas Deteksi Sentuhan Layar Gawai Seluler
    track.addEventListener("touchstart", () => { activeSpeed = 0; });
    track.addEventListener("touchend", () => { activeSpeed = currentSpeed; });
});
</script>




        
        
