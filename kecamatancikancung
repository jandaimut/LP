    var logo = document.querySelectorAll('.logo-kompascom');
    logo.forEach(item => {
        const logo_url = new URL(item.href);
        logo_url.searchParams.set('refresh_attempt', attempt);
        item.setAttribute('href', logo_url.toString());
    });
  });
